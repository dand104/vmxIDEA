<idea-plugin>
    <id>org.vmxidea.vmxidea</id>

    <name>VmxIDEA</name>

    <vendor url="https://github.com/dand104">dand104</vendor>

    <description><![CDATA[
        VMware Workstation virtual machines (.vmx) integration into inteliJ platform.

    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <projectConfigurable parentId="tools" instance="org.vmxidea.vmxidea.presentation.settings.VmwareSettingsConfigurable"
                             id="presentation.settings.VmwareSettingsConfigurable" displayName="VmxIDEA"/>

        <notificationGroup id="vmxIDEA" displayType="BALLOON"/>

        <postStartupActivity implementation="org.vmxidea.vmxidea.presentation.lifecycle.VmStartupActivity"/>
    </extensions>

    <applicationListeners>
        <listener class="org.vmxidea.vmxidea.presentation.lifecycle.VmProjectCloseListener" topic="com.intellij.openapi.project.ProjectManagerListener"/>
    </applicationListeners>

    <actions>
        <group id="VmxIdea.ToolbarGroup" text="VmxIDEA" popup="false">
            <action id="VmxIdea.SelectTargetVm" class="org.vmxidea.vmxidea.presentation.actions.TargetVmComboBoxAction" />
            <action id="VmxIdea.Toggle" class="org.vmxidea.vmxidea.presentation.actions.ToggleVmAction" text="Start VM" icon="AllIcons.Actions.Execute"/>

            <separator/>
            <add-to-group group-id="RunToolbarMainActionGroup" anchor="last"/>
        </group>
    </actions>

</idea-plugin>